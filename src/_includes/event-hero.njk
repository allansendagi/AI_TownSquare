{# ============================================
   EVENT HERO — Multi-State Component
   Three variants: pre-event, live, post-event
   Visibility controlled by CSS based on body class
   ============================================ #}
<section class="dubai-hero">
  <div class="container">
    <div class="dubai-hero-content">

      {# ===== PRE-EVENT STATE ===== #}
      <div class="pre-event-only">
        <div class="dubai-hero-eyebrow">AI TownSquare &middot; Dubai Node<br/>3 April 2026</div>

        <h1 class="dubai-hero-question">
          Is AI Going to Take Our Jobs?
        </h1>

        <p class="dubai-hero-sub">
          25 cross-sector participants examine one of the defining questions of the AI era through a structured 60-minute civic dialogue.
        </p>

        <div class="readiness-clock" id="countdown">
          <div class="readiness-clock-label">Global Readiness Clock</div>
          <div class="readiness-clock-units">
            <div class="readiness-clock-unit">
              <span class="readiness-clock-value" id="cd-days">--</span>
              <span class="readiness-clock-name">Days</span>
            </div>
            <div class="readiness-clock-unit">
              <span class="readiness-clock-value" id="cd-hours">--</span>
              <span class="readiness-clock-name">Hours</span>
            </div>
            <div class="readiness-clock-unit">
              <span class="readiness-clock-value" id="cd-min">--</span>
              <span class="readiness-clock-name">Min</span>
            </div>
            <div class="readiness-clock-unit">
              <span class="readiness-clock-value" id="cd-sec">--</span>
              <span class="readiness-clock-name">Sec</span>
            </div>
          </div>
        </div>

        <div class="dubai-hero-actions">
          <a href="/dubai-rsvp/" class="btn btn--primary">
            0 of 25 Seats &middot JOIN THE AI TOWNSQUARE WAITLIST
            <span class="btn-arrow">&rarr;</span>
          </a>
        </div>

        {# Livestream Preview - inside pre-event-only #}
        <div class="livestream-preview">
          <div class="livestream-preview-badge">
            <span class="livestream-preview-icon">&#9737;</span>
            Broadcasting Worldwide
          </div>
          <p class="livestream-preview-text">
            Are you outside Dubai? Watch AI TownSquare live from anywhere on Earth.
          </p>
          <a href="https://youtube.com/live/dW4XoVqgIXU?feature=share" class="btn btn--ghost" target="_blank" rel="noopener">
            <span class="yt-icon">&#9654;</span>
            Subscribe to Watch Live
          </a>
        </div>
      </div>

      {# ===== LIVE STATE ===== #}
      <div class="live-only">
        <div class="live-badge">
          <span class="live-badge-dot"></span>
          Live Now
        </div>

        <div class="dubai-hero-eyebrow">AI TownSquare &middot; Dubai Node<br/>3 April 2026</div>

        <h1 class="dubai-hero-question">
          Is AI Going to Take Our Jobs?
        </h1>

        <p class="dubai-hero-sub">
          Watch the live dialogue as 25 cross-sector participants examine one of the defining questions of the AI era.
        </p>

        {# YouTube Live Embed - uses channel ID to auto-show current livestream #}
        <div class="youtube-embed-wrap" id="youtubeEmbed">
          <iframe
            src="https://www.youtube.com/embed/live_stream?channel=UC4nNC0GSVCtmRJBFRh_9z-Q&autoplay=1&rel=0&modestbranding=1"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            title="AI TownSquare Dubai Live Stream"
          ></iframe>
          <div class="youtube-fallback" style="display: none;">
            <span class="youtube-fallback-icon">&#9654;</span>
            <span class="youtube-fallback-text">Stream loading...</span>
            <a href="https://www.youtube.com/channel/UC4nNC0GSVCtmRJBFRh_9z-Q/live" class="btn btn--primary" target="_blank" rel="noopener">
              Watch on YouTube
              <span class="btn-arrow">&rarr;</span>
            </a>
          </div>
        </div>

        <div class="dubai-hero-actions">
          <a href="https://www.youtube.com/channel/UC4nNC0GSVCtmRJBFRh_9z-Q/live" class="btn btn--secondary" target="_blank" rel="noopener">
            Watch on YouTube
            <span class="btn-arrow">&rarr;</span>
          </a>
        </div>
      </div>

      {# ===== POST-EVENT STATE ===== #}
      <div class="post-event-only">
        <div class="post-event-badge">
          <span class="post-event-badge-icon">&#10003;</span>
          Dialogue Complete
        </div>

        <div class="dubai-hero-eyebrow">AI TownSquare &middot; Dubai Node<br/>3 April 2026</div>

        <h1 class="dubai-hero-question">
          Is AI Going to Take Our Jobs?
        </h1>

        <p class="dubai-hero-sub">
          25 voices. 60 minutes. One question that matters. Watch the full dialogue.
        </p>

        {# YouTube Recording Embed #}
        <div class="youtube-embed-wrap">
          <iframe
            src="https://www.youtube.com/embed/dW4XoVqgIXU?rel=0&modestbranding=1"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            title="AI TownSquare Dubai Recording"
          ></iframe>
        </div>

        {# Civic Brief Countdown #}
        <div class="civic-brief-countdown" id="civicBriefCountdown">
          <div class="civic-brief-countdown-badge">
            <span class="civic-brief-countdown-icon">&#9998;</span>
            In Progress
          </div>
          <div class="civic-brief-countdown-label">Civic Brief Publication</div>
          <div class="civic-brief-countdown-timer">
            <div class="civic-brief-countdown-unit">
              <span class="civic-brief-countdown-value" id="cb-hours">--</span>
              <span class="civic-brief-countdown-name">Hours</span>
            </div>
            <div class="civic-brief-countdown-unit">
              <span class="civic-brief-countdown-value" id="cb-min">--</span>
              <span class="civic-brief-countdown-name">Min</span>
            </div>
            <div class="civic-brief-countdown-unit">
              <span class="civic-brief-countdown-value" id="cb-sec">--</span>
              <span class="civic-brief-countdown-name">Sec</span>
            </div>
          </div>
          <p class="civic-brief-countdown-message">
            Our team is synthesizing 60 minutes of cross-sector dialogue into a permanent civic record.
          </p>
        </div>

        {# Civic Brief Available - shown after deadline #}
        <div class="civic-brief-available" id="civicBriefAvailable" style="display: none;">
          <div class="civic-brief-available-badge">
            <span class="civic-brief-available-icon">&#10003;</span>
            Civic Brief Published
          </div>
        </div>

        <div class="dubai-hero-actions">
          <a href="/briefs/CB-DXB-001/" class="btn btn--primary civic-brief-link" id="civicBriefBtn" style="display: none;">
            Read the Civic Brief
            <span class="btn-arrow">&rarr;</span>
          </a>
          <a href="https://www.youtube.com/watch?v=dW4XoVqgIXU" class="btn btn--secondary" target="_blank" rel="noopener">
            Watch on YouTube
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
