<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | AI TownSquare</title>
  <meta name="description" content="{{ description or 'Civic infrastructure for the intelligence age. Bridging the gap between AI advancement and societal readiness.' }}" />
  <meta name="theme-color" content="#080808" />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />

  <!-- Canonical URL -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }} | AI TownSquare" />
  <meta property="og:description" content="{{ description or 'Civic infrastructure for the intelligence age.' }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ site.url }}/assets/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="AI TownSquare" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@AITownSquare" />
  <meta name="twitter:title" content="{{ title }} | AI TownSquare" />
  <meta name="twitter:description" content="{{ description or 'Civic infrastructure for the intelligence age.' }}" />
  <meta name="twitter:image" content="{{ site.url }}/assets/og-image.jpg" />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />

  <!-- Fonts with font-display swap for faster rendering -->
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- CSS -->
  <link rel="stylesheet" href="/css/tokens.css" />
  <link rel="stylesheet" href="/css/reset.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/nav.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/hero.css" />
  <link rel="stylesheet" href="/css/sections.css" />
  <link rel="stylesheet" href="/css/footer.css" />
  <link rel="stylesheet" href="/css/responsive.css" />
  {% if extraCss %}
  {% for css in extraCss %}
  <link rel="stylesheet" href="{{ css }}" />
  {% endfor %}
  {% endif %}

  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-xtZt_rhujA2ywdxUHzUEX.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LH37Y4RK99"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LH37Y4RK99');
  </script>

  <!-- Structured Data: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "AI TownSquare",
    "url": "https://aitownsquare.org",
    "logo": "https://aitownsquare.org/assets/Logo_Black.png",
    "description": "Civic dialogue platform examining societal implications of AI through structured conversations. 25 curated participants, 60 minutes, one published civic record.",
    "founder": {
      "@type": "Person",
      "name": "Allan Sendagi"
    },
    "foundingLocation": {
      "@type": "Place",
      "name": "Doha, Qatar"
    },
    "sameAs": [
      "https://www.linkedin.com/company/aitownsquare",
      "https://x.com/AITownSquare"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "info@aitownsquare.org",
      "contactType": "General Inquiry"
    },
    "subjectOf": {
      "@type": "NewsArticle",
      "headline": "AI TownSquare launches in Dubai to examine the societal impact of artificial intelligence",
      "url": "https://businesstoday.me/show-report/ai-townsquare-launches-in-dubai-to-examine-the-societal-impact-of-artificial-intelligence/",
      "publisher": {
        "@type": "Organization",
        "name": "BusinessToday ME"
      }
    }
  }
  </script>

  <!-- Structured Data: WebSite -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AI TownSquare",
    "url": "https://aitownsquare.org",
    "description": "Civic Infrastructure for the Intelligence Age"
  }
  </script>

  <!-- Structured Data: BreadcrumbList -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://aitownsquare.org/"
      }{% if page.url != "/" %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{ title }}",
        "item": "https://aitownsquare.org{{ page.url }}"
      }{% endif %}
    ]
  }
  </script>
</head>

<body>
  {% include "nav.njk" %}

  {{ content | safe }}

  {% include "footer.njk" %}

  <!-- JS -->
  <script src="/js/shared.js"></script>
  <script src="/js/analytics.js"></script>
  {% if extraJs %}
  {% for js in extraJs %}
  <script src="{{ js }}"></script>
  {% endfor %}
  {% endif %}
</body>
</html>
