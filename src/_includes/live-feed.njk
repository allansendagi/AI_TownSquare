{# Live Synthesis Feed — polls mock JSON during event #}
<section class="live-feed" id="liveFeed">
  <div class="container">
    <div class="live-feed-header reveal">
      <div class="live-feed-pulse"></div>
      <span class="label label--accent">Live Synthesis Feed</span>
      <h2 class="live-feed-title">Emerging Insights</h2>
      <p class="live-feed-sub">Short insights captured during the dialogue as the Civic Brief begins to take shape.</p>
      <button class="live-feed-toggle" id="liveFeedToggle" aria-expanded="true" aria-controls="liveFeedStream">
        <span class="live-feed-toggle-text">Hide Insights</span>
        <span class="live-feed-toggle-icon"></span>
      </button>
    </div>
    <div class="live-feed-stream" id="liveFeedStream">
      <!-- Populated by live-feed.js -->
    </div>
  </div>
</section>
